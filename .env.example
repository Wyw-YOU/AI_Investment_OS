# App
APP_NAME=AI Investment OS
DEBUG=false

# Database
DATABASE_URL=sqlite:///./data/investment.db

# Redis
REDIS_URL=redis://localhost:6379/0

# ============================================================
# LLM Configuration — OpenAI-compatible interface
# Supports: OpenAI, DeepSeek, Qwen, MiMo, Moonshot, etc.
# Switch provider by changing LLM_BASE_URL + LLM_API_KEY + LLM_MODEL
# ============================================================

# --- Option 1: OpenAI ---
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-openai-key
# LLM_MODEL=gpt-4o-mini

# --- Option 2: DeepSeek (推荐，性价比高) ---
# LLM_BASE_URL=https://api.deepseek.com
# LLM_API_KEY=sk-your-deepseek-key
# LLM_MODEL=deepseek-chat

# --- Option 3: 通义千问 / Qwen (阿里云) ---
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-your-qwen-key
# LLM_MODEL=qwen-plus

# --- Option 4: 小米 MiMo ---
# LLM_BASE_URL=https://api.xiaomi.com/v1
# LLM_API_KEY=sk-your-mimo-key
# LLM_MODEL=MiMo-7B

# --- Option 5: Moonshot (月之暗面 / Kimi) ---
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_API_KEY=sk-your-moonshot-key
# LLM_MODEL=moonshot-v1-8k

# --- Option 6: 硅基流动 SiliconFlow (多模型聚合) ---
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_API_KEY=sk-your-siliconflow-key
# LLM_MODEL=deepseek-ai/DeepSeek-V3

# --- Default (pick one above and uncomment) ---
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=2000

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# JWT
JWT_SECRET=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
